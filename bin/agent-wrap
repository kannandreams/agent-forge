#!/usr/bin/env python3
"""Terminal wrapper for agent-forge."""

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path


DEFAULT_SOURCE = "kannandreams/agent-forge"
DEFAULT_NPX_PACKAGE = "skills"


@dataclass(frozen=True)
class Skill:
    name: str
    description: str
    path: Path


def repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


ROOT = repo_root()


def parse_frontmatter_value(path: Path, key: str) -> str | None:
    prefix = f"{key}:"
    for line in path.read_text(encoding="utf-8").splitlines():
        if line.startswith(prefix):
            return line.removeprefix(prefix).strip()
    return None


def load_skills() -> list[Skill]:
    skills: list[Skill] = []
    for path in sorted(ROOT.glob("skills/*/*/SKILL.md")):
        name = parse_frontmatter_value(path, "name") or path.parent.name
        description = parse_frontmatter_value(path, "description") or "No description"
        skills.append(Skill(name=name, description=description, path=path.relative_to(ROOT)))
    return skills


def load_docs() -> list[Path]:
    docs: list[Path] = []
    for name in ("README.md", "AGENTS.md", "CHANGELOG.md", "TODO.md"):
        path = ROOT / name
        if path.exists():
            docs.append(path.relative_to(ROOT))

    for folder in ("docs", "workflows", "templates", "examples"):
        docs.extend(path.relative_to(ROOT) for path in sorted((ROOT / folder).glob("*.md")))

    return docs


def clear_screen() -> None:
    if sys.stdout.isatty() and os.environ.get("TERM") and shutil.which("clear"):
        subprocess.run(["clear"], check=False)
    else:
        print()


def print_header() -> None:
    clear_screen()
    print("agent-wrap")
    print("==========")
    print()


def pause() -> None:
    try:
        input("\nPress Enter to continue...")
    except EOFError:
        return


def print_skills(skills: list[Skill]) -> None:
    for index, skill in enumerate(skills, start=1):
        print(f"{index:2d}. {skill.name:<42} {skill.description}")


def shell_quote(value: str) -> str:
    return subprocess.list2cmdline([value])


def install_command(args: argparse.Namespace, skill: Skill) -> list[str]:
    return [
        "npx",
        args.npx_package,
        "add",
        args.source,
        skill.path.as_posix(),
    ]


def print_command(command: list[str]) -> None:
    print("  " + " ".join(shell_quote(part) for part in command))


def run_skill_install(args: argparse.Namespace, skill: Skill) -> None:
    command = install_command(args, skill)

    print_header()
    print(f"Install skill: {skill.name}")
    print()
    print(f"Source: {args.source}")
    print(f"Path:   {skill.path.as_posix()}")
    print()

    if args.dry_run:
        print("Dry run command:")
        print_command(command)
        pause()
        return

    if shutil.which("npx") is None:
        print("npx was not found in PATH.", file=sys.stderr)
        print()
        print("Command to run when npx is available:")
        print_command(command)
        pause()
        return

    print("Running:")
    print_command(command)
    print()
    subprocess.run(command, check=False)
    pause()


def install_skill_menu(args: argparse.Namespace, skills: list[Skill]) -> None:
    while True:
        print_header()
        print("Install a skill")
        print()
        print_skills(skills)
        print()
        print("0. Back")
        print()

        choice = read_choice("Select a skill: ")
        if choice in {"0", "q", "Q"}:
            return

        if choice.isdigit():
            index = int(choice) - 1
            if 0 <= index < len(skills):
                run_skill_install(args, skills[index])


def ansi(code: str) -> str:
    if sys.stdout.isatty() and os.environ.get("TERM"):
        return f"\033[{code}m"
    return ""


def render_markdown_line(line: str) -> str:
    bold = ansi("1")
    cyan = ansi("36")
    normal = ansi("0")

    if line.startswith("# "):
        return f"{bold}{line[2:]}{normal}"
    if line.startswith("## "):
        return f"\n{cyan}{line[3:]}{normal}"
    if line.startswith("### "):
        return f"\n{bold}{line[4:]}{normal}"
    if line.startswith("- "):
        return f"  - {line[2:]}"
    return line


def read_single_key() -> str:
    if not sys.stdin.isatty():
        try:
            return input()
        except EOFError:
            return ""

    import termios
    import tty

    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        return sys.stdin.read(1)
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)


class AlternateScreen:
    def __enter__(self) -> None:
        if sys.stdout.isatty() and os.environ.get("TERM"):
            sys.stdout.write("\033[?1049h")
            sys.stdout.flush()

    def __exit__(self, exc_type: object, exc: object, tb: object) -> None:
        if sys.stdout.isatty() and os.environ.get("TERM"):
            sys.stdout.write("\033[?1049l")
            sys.stdout.flush()


def view_markdown(path: Path) -> None:
    absolute = ROOT / path

    with AlternateScreen():
        clear_screen()
        print(f"Viewing {path.as_posix()}")
        print("Press Esc, q, or Enter to return.")
        print("----------------------------------------")
        print()

        for line in absolute.read_text(encoding="utf-8").splitlines():
            print(render_markdown_line(line))

        print()
        print("----------------------------------------")
        print("Press Esc, q, or Enter to return.", end="", flush=True)

        while True:
            key = read_single_key()
            if key in {"\x1b", "q", "Q", "", "\n", "\r"}:
                break


def docs_menu() -> None:
    docs = load_docs()

    while True:
        print_header()
        print("View Markdown docs")
        print()

        for index, path in enumerate(docs, start=1):
            print(f"{index:2d}. {path.as_posix()}")

        print()
        print("0. Back")
        print()

        choice = read_choice("Select a doc: ")
        if choice in {"0", "q", "Q"}:
            return

        if choice.isdigit():
            index = int(choice) - 1
            if 0 <= index < len(docs):
                view_markdown(docs[index])


def capabilities_menu(skills: list[Skill]) -> None:
    print_header()
    print("Capabilities")
    print()
    print_skills(skills)
    pause()


def show_install_format(args: argparse.Namespace) -> None:
    command = [
        "npx",
        args.npx_package,
        "add",
        args.source,
        "skills/github/code-review/SKILL.md",
    ]

    print_header()
    print("Command format:")
    print()
    print(f"  npx {args.npx_package} add {args.source} <skill-path>")
    print()
    print("Example:")
    print()
    print_command(command)
    pause()


def read_choice(prompt: str) -> str:
    try:
        return input(prompt).strip()
    except EOFError:
        return "0"


def main_menu(args: argparse.Namespace) -> int:
    skills = load_skills()

    while True:
        print_header()
        print("1. Install a skill with npx")
        print("2. View rendered Markdown docs")
        print("3. List capabilities")
        print("4. Show install command format")
        print("0. Exit")
        print()

        choice = read_choice("Select an option: ")
        if choice == "1":
            install_skill_menu(args, skills)
        elif choice == "2":
            docs_menu()
        elif choice == "3":
            capabilities_menu(skills)
        elif choice == "4":
            show_install_format(args)
        elif choice in {"0", "q", "Q"}:
            return 0


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="agent-wrap",
        description=(
            "TUI wrapper for browsing agent-forge capabilities, viewing Markdown "
            "docs, and installing skills through npx."
        ),
    )
    parser.add_argument(
        "--source",
        default=os.environ.get("AGENT_WRAP_SOURCE", DEFAULT_SOURCE),
        help=f"skill source repo (default: {DEFAULT_SOURCE})",
    )
    parser.add_argument(
        "--npx-package",
        default=os.environ.get("AGENT_WRAP_NPX_PACKAGE", DEFAULT_NPX_PACKAGE),
        help=f"npx package name for the skills CLI (default: {DEFAULT_NPX_PACKAGE})",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="print install commands instead of running them",
    )
    parser.add_argument(
        "--list-skills",
        action="store_true",
        help="print available skills and exit",
    )
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)

    if args.list_skills:
        print_skills(load_skills())
        return 0

    return main_menu(args)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
